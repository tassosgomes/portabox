{
  "Cors": {
    "AllowedOrigins": [
      "https://admin.portabox.com",
      "https://app.portabox.com"
    ]
  },
  "Storage": {
    "Provider": "S3",
    "BucketName": "log-portaria-production",
    "Region": "auto",
    "ForcePathStyle": false,
    "UseSsl": true,
    "PresignedUrlTtlMinutes": 5
  },
  "Email": {
    "Provider": "Smtp",
    "Host": "smtp.portabox.com",
    "Port": 587,
    "FromAddress": "no-reply@portabox.com",
    "UseStartTls": true
  },
  "DomainEvents": {
    "Publisher": {
      "Enabled": true,
      "BatchSize": 100,
      "PollInterval": "00:00:15"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
