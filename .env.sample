# PortaBox API — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env to source control.

# ── Database ────────────────────────────────────────────────────────────────
ConnectionStrings__Postgres=Host=<host>;Port=5432;Database=portabox;Username=<user>;Password=<password>

# ── Object Storage (S3-compatible) ──────────────────────────────────────────
Storage__Provider=S3
Storage__BucketName=<bucket-name>
Storage__Region=<region>
Storage__Endpoint=<endpoint-url>          # omit for real AWS S3
Storage__AccessKey=<access-key-id>
Storage__SecretKey=<secret-access-key>
Storage__UseSsl=true
Storage__ForcePathStyle=false
Storage__PresignedUrlTtlMinutes=5

# ── Email / SMTP ─────────────────────────────────────────────────────────────
Email__Provider=Smtp
Email__Host=<smtp-host>
Email__Port=587
Email__FromAddress=no-reply@<your-domain>
Email__Username=<smtp-username>
Email__Password=<smtp-password>
Email__UseStartTls=true                   # REQUIRED true in Production

# ── ASP.NET Core Data Protection ────────────────────────────────────────────
# Mount a durable volume at this path so cookies survive restarts.
DataProtection__KeysPath=/var/portabox/dp-keys

# ── CORS ─────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=https://admin.<your-domain>
Cors__AllowedOrigins__1=https://app.<your-domain>

# ── Magic Link base URL (Síndico SPA) ────────────────────────────────────────
CondominioMagicLink__SindicoAppBaseUrl=https://app.<your-domain>

# ── Rate Limiting (optional tuning) ─────────────────────────────────────────
# RateLimiting__Auth__MaxRequests=10
# RateLimiting__Auth__WindowMinutes=10

# ── Persistence ──────────────────────────────────────────────────────────────
# Persistence__ApplyMigrationsOnStartup=true

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://<otel-collector>:4317
# OTEL_SERVICE_NAME=portabox-api
